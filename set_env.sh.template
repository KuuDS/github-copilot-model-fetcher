#!/bin/bash
# Environment configuration for GitHub Copilot Model Fetcher
# Usage: source ./set_env.sh
#
# This script sets temporary environment variables for the current shell session.
# No permanent changes are made to ~/.bashrc or ~/.zshrc
#
# Setup:
#   1. Copy this file to set_env.sh: cp set_env.sh.template set_env.sh
#   2. Edit set_env.sh and fill in your GITHUB_CLIENT_ID
#   3. Run: source ./set_env.sh
#   4. Then use: ./auth.sh, ./fetch.sh, ./list.sh

# ============================================================================
# REQUIRED CONFIGURATION - Edit these values
# ============================================================================

# GitHub OAuth App Client ID
# Get it from: https://github.com/settings/developers
# Create OAuth App -> Enable Device Flow -> Copy Client ID
export GITHUB_CLIENT_ID=""

# Example:
# export GITHUB_CLIENT_ID="Ov23liAbCdEfGhIjKlM"

# ============================================================================
# OPTIONAL CONFIGURATION - Uncomment and modify if needed
# ============================================================================

# Custom data directory (default: ~/.copilot-fetcher)
# export COPILOT_FETCHER_DATA_DIR="$HOME/.copilot-fetcher"

# Proxy settings (if behind corporate firewall)
# export HTTP_PROXY="http://proxy.company.com:8080"
# export HTTPS_PROXY="http://proxy.company.com:8080"

# ============================================================================
# VALIDATION
# ============================================================================

if [[ -z "$GITHUB_CLIENT_ID" ]]; then
    echo "Error: GITHUB_CLIENT_ID is not set"
    echo ""
    echo "To fix:"
    echo "  1. Copy template: cp set_env.sh.template set_env.sh"
    echo "  2. Edit set_env.sh and add your Client ID"
    echo "  3. Run: source ./set_env.sh"
    echo ""
    return 1 2>/dev/null || exit 1
fi

# Get script directory
export COPILOT_FETCHER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Check virtual environment
if [[ -d "$COPILOT_FETCHER_DIR/.venv" ]]; then
    export COPILOT_FETCHER_VENV="$COPILOT_FETCHER_DIR/.venv"
else
    echo "Error: Virtual environment not found"
    echo "Please run: uv venv && uv pip install -e ."
    return 1 2>/dev/null || exit 1
fi

echo "✓ Environment configured"
echo "  GITHUB_CLIENT_ID: ${GITHUB_CLIENT_ID:0:10}..."
